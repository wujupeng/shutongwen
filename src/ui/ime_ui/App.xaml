<Application
    x:Class="ShuTongWen.UI.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:ShuTongWen.UI">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls" />
            </ResourceDictionary.MergedDictionaries>

            <DataTemplate x:Key="CandidateItemTemplate" x:DataType="local:CandidateItem">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Stretch">
                    <TextBlock Text="{Binding Index}" Width="32" FontSize="14" 
                               Foreground="{ThemeResource SystemAccentColor}"/>
                    <TextBlock Text="{Binding Text}" FontSize="16" FontFamily="Microsoft YaHei UI"
                               Foreground="{ThemeResource SystemForegroundColor}"
                               Margin="8, 0"/>
                    <TextBlock Text="{Binding Pinyin}" FontSize="12" 
                               Foreground="{ThemeResource SystemDisabledColor}"
                               Margin="8, 0, 0, 0"/>
                </StackPanel>
            </DataTemplate>
        </ResourceDictionary>
    </Application.Resources>
</Application>